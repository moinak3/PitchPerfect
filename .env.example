# No external API keys required for local operation.
# Whisper runs fully locally. CREPE runs locally via TensorFlow/PyTorch.
# yt-dlp downloads audio without an API key.

# Optional: set this to use a larger Whisper model for better transcription accuracy.
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base

# Optional: CREPE model capacity. Larger = more accurate, slower.
# Options: tiny, small, medium, large, full
CREPE_MODEL=small
